# --- Maven (Java) Exclusions ---
**/target/
**/*.class
**/*.jar
**/*.war
**/*.ear
.mvn/

# --- Node / Frontend Exclusions ---
**/node_modules/
**/dist/
.env
.env.local
.env.production
.env.production.local
.eslintcache

# --- Backend local credential files (never commit these) ---
backend/.env
backend/**/.env

# --- IDE and Editor Exclusions ---
.idea/
.vscode/
*.iml
*.ipr
*.iws
.classpath
.project
.settings/
.metadata/

# --- System and Log Exclusions ---
*.log
.DS_Store
Thumbs.db

# --- Local Properties for backend (sensitive configs) ---
**/application-local.properties

# --- Internal Agent Folders ---
.agents/
**/brain/
**/logs/


