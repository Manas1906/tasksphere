# TaskSphere Enterprise - Frontend Environment Variables Template
# Copy this file to '.env' inside the same directory and populate your private keys.
# NEVER commit the actual '.env' file containing raw keys to GitHub.

# Base API endpoint pointing to your active Spring Boot backend
VITE_API_URL=http://localhost:8080

# Live Google Gemini Developer Key (Generate free key via Google AI Studio)
VITE_GEMINI_API_KEY=

# Razorpay - PUBLIC Key ID only. Get from: https://dashboard.razorpay.com/app/website-app-settings/api-keys
# KEY_SECRET must ONLY go in backend application.properties or server env vars — NEVER here.
VITE_RAZORPAY_KEY_ID=
